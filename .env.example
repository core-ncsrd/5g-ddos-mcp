# ─────────────────────────────────────────────────────────────────────────────
# 5G-DDoS MCP Server — Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Backend ──────────────────────────────────────────────────────────────
# Choose ONE: claude | ollama | openai_compatible
LLM_BACKEND=claude

# ── Claude (Anthropic) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ── Ollama (local open-source LLMs) ──────────────────────────────────────────
# Pull a model first: ollama pull llama3.2
# Other options: mistral | phi4 | gemma3 | deepseek-r1 | qwen2.5
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── OpenAI-compatible endpoint ────────────────────────────────────────────────
# Works with: vLLM, LM Studio, Groq, Together.ai, Mistral API, etc.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── LLM Generation Parameters ────────────────────────────────────────────────
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3

# ── MCP Server ────────────────────────────────────────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=8000
LOG_LEVEL=INFO

# ── Detection Threshold ───────────────────────────────────────────────────────
# Probability above which a sample is classified as an attack (0.0–1.0)
ANOMALY_THRESHOLD=0.5

# ── Auto-Response API (optional) ─────────────────────────────────────────────
# Generic REST endpoint for auto-executing mitigation actions (blacklist, rate-limit, etc.)
# Works with Open5GS, free5GC, OAI, or any custom network management system
# Leave empty to use recommendation-only mode (no auto-execution)
RESPONSE_API_URL=
RESPONSE_API_KEY=

